<mujoco model="yam_scene">
  <compiler angle="radian" meshdir="i2rt/i2rt/robot_models/arm/yam/assets"/>
  <option timestep="0.002"/>
  <visual>
    <global offwidth="1024" offheight="1024"/>
    <quality shadowsize="2048"/>
    <headlight diffuse="0.55 0.55 0.55" ambient="0.45 0.45 0.45" specular="0.1 0.1 0.1"/>
  </visual>

  <default>
    <!-- Uniform matte-aluminum look for all robot links -->
    <default class="yam_link">
      <geom type="mesh" rgba="0.78 0.78 0.80 1.0"
            material="aluminum"
            density="800"/>
    </default>
    <default class="yam_dark">
      <geom type="mesh" rgba="0.20 0.20 0.22 1.0"
            material="dark_plastic"
            density="800"/>
    </default>
  </default>

  <asset>
    <mesh name="base"  file="base.stl"/>
    <mesh name="link1" file="link1.stl"/>
    <mesh name="link2" file="link2.stl"/>
    <mesh name="link3" file="link3.stl"/>
    <mesh name="link4" file="link4.stl"/>
    <mesh name="link5" file="link5.stl"/>
    <mesh name="gripper_body" file="gripper.stl"/>
    <mesh name="tip_left"     file="tip_left.stl"/>
    <mesh name="tip_right"    file="tip_right.stl"/>
    <material name="aluminum"    rgba="0.78 0.78 0.80 1.0" specular="0.4" shininess="0.6" reflectance="0.05"/>
    <material name="dark_plastic" rgba="0.20 0.20 0.22 1.0" specular="0.1" shininess="0.2"/>
    <texture name="floor" type="2d" builtin="flat" rgb1="0 0 0" width="64" height="64"/>
    <material name="floor" texture="floor" reflectance="0.0"/>
    <texture name="sky" type="skybox" builtin="flat" rgb1="0 0 0" rgb2="0 0 0" width="32" height="32"/>
  </asset>

  <worldbody>
    <light name="L1" pos="0 0 1.6"  dir="0 0 -1"   diffuse="0.45 0.45 0.45"/>
    <light name="L2" pos="0.4 0 1.3" dir="-0.3 0 -1" diffuse="0.25 0.25 0.25"/>
    <geom name="floor" type="plane" pos="0 0 0" size="2 2 0.05" rgba="0 0 0 1" material="floor"/>

    <!-- Top-down ceiling camera matching the scene_rgb_2 perspective.
         xyaxes="1 0 0  0 1 0" makes the camera look straight down at -z,
         with world+x → image right, world+y → image up. Since the operator
         in the dataset is on the LEFT of the image, both YAM bases live at
         world -x (so they appear on the LEFT) and reach toward +x (the
         mat in the center / right). -->
    <camera name="scene" pos="0 0 1.10" xyaxes="1 0 0  0 1 0" fovy="70"/>

    <!-- ARM 1 in WORLD frame matched to Vive calibration:
         arms extend in world +y direction, which projects to image-RIGHT
         in this scene-cam view (R_w2c[0] ≈ world+y). YAM bases sit at low
         world -y so they appear on the image LEFT, with the arm reaching
         forward toward the operator's gripper workspace. -->
